<server description="Worklog Microservice">
    <!-- tag::featureManager[] -->
    <featureManager>
        <platform>jakartaee-10.0</platform>
        <platform>microprofile-7.1</platform>
        <feature>beanValidation</feature>
        <!-- tag::cdiFeature[] -->
        <feature>cdi</feature>
        <!-- end::cdiFeature[] -->
        <feature>jsonb</feature>
        <!-- tag::passwordUtilFeature[] -->
        <feature>passwordUtilities-1.1</feature>
        <!-- end::passwordUtilFeature[] -->
        <feature>restfulWS</feature>
        <!-- tag::sslFeature[] -->
        <feature>ssl-1.0</feature>
        <!-- end::sslFeature[] -->
        <!-- tag::mpConfigFeature[] -->
        <feature>mpConfig</feature>
        <!-- end::mpConfigFeature[] -->
        <feature>mpOpenAPI</feature>
        <!-- to verify JWT -->
        <feature>mpJwt</feature>


    </featureManager>
    <!-- end::featureManager[] -->
    <variable name="http.port" defaultValue="9081" />
    <variable name="https.port" defaultValue="9441" />
    <variable name="app.context.root" defaultValue="/worklog/" />
    <!-- tag::httpEndpoint[] -->
    <httpEndpoint
        host="*"
        httpPort="${http.port}"
        httpsPort="${https.port}"
        id="defaultHttpEndpoint"
    />
    <!-- end::httpEndpoint[] -->

    <!-- tag::webApplication[] -->
    <webApplication
        location="worklog.war"
        contextRoot="${app.context.root}">
        <application-bnd>
            <security-role name="student">
                <special-subject type="ALL_AUTHENTICATED_USERS" />
            </security-role>
            <security-role name="instructor">
                <special-subject type="ALL_AUTHENTICATED_USERS" />
            </security-role>
        </application-bnd>
    </webApplication>
    <!-- end::webApplication[] -->
    <mpJwt id="defaultMpJwt"
        userNameAttribute="email"
        mapToUserRegistry="false"
        clockSkew="0s"
    />

</server>